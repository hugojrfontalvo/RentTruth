# Comma-separated admin owner emails that may access /admin and /hq/support.
RENTTRUTH_ADMIN_EMAILS=admin@renttruth.com
ADMIN_EMAIL=admin@renttruth.com

# Public production URL for canonical metadata and future external links.
NEXT_PUBLIC_APP_URL=https://renttruth.io
APP_PUBLIC_URL=https://renttruth.io

# Optional Google Places key for landlord property address autocomplete.
# Manual address entry remains available when this is blank.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional feedback notifications. EMAIL_PROVIDER_API_KEY uses Resend-compatible email sending.
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM=RentTruth <notifications@renttruth.io>
SMS_PROVIDER_API_KEY=
ADMIN_PHONE_NUMBER=

# Demo seed data is opt-in. Leave false/blank in production so admin counts only real users.
RENTTRUTH_ENABLE_DEMO_DATA=false

# Production database. Use Vercel Postgres, Neon, Supabase, or any Postgres URL.
# RentTruth checks DATABASE_URL first, then POSTGRES_URL, POSTGRES_PRISMA_URL,
# and POSTGRES_URL_NON_POOLING. When one is set, durable app data is saved there
# instead of the local JSON file.
DATABASE_URL=
POSTGRES_URL=

# Persistent JSON store path. In production, point this to a writable durable volume.
RENTTRUTH_DATA_FILE=./data/renttruth-db.json

# Persistent upload directory. In production, point this to a writable durable volume.
RENTTRUTH_UPLOAD_DIR=./data/uploads
